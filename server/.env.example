# Copy this file to .env and fill in the values for local development.
# Never commit .env — it is gitignored.
# For Azure App Service, set these under Configuration > Application Settings.

POWER_AUTOMATE_WEBHOOK=<your-power-automate-webhook-url>
POWER_AUTOMATE_API_KEY=<your-power-automate-api-key>

# Optional: tighten CORS in production (defaults to http://localhost:5173)
ALLOWED_ORIGIN=https://<your-azure-app>.azurewebsites.net
